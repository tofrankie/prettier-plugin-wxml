<!--
  回归覆盖（对齐规划：混合文本 / 多插值 / 算术逻辑 / 一元括号 / 三元 / 可选链 /
  数组与对象 / template·data 简写 / 函数与箭头 / 字符串内 }} 与 {{ /
  注释跳过与混合 / 非法与语句容错 / }} 与引号间空格 等）。
  每项含「文本节点」与「属性值插值」对照；属性内若含双引号字符串，外层属性用单引号包裹。
  说明：整文件解析失败、throwOnError、reportLevel 见 tests/index.test.ts。
-->

<!-- example：小程序页面片段 -->
<view class="container">
  <view class="userinfo">
    <block wx:if="{{ canIUseNicknameComp && !hasUserInfo }}">
      <button class="avatar-wrapper" bind:chooseavatar="onChooseAvatar" open-type="chooseAvatar">
        <image class="avatar" src="{{ userInfo.avatarUrl }}"></image>
      </button>
      <view class="nickname-wrapper">
        <text class="nickname-label">昵称</text>
        <input
          class="nickname-input"
          bind:change="onInputChange"
          placeholder="请输入昵称"
          type="nickname"
        />
      </view>
    </block>
    <block wx:elif="{{ !hasUserInfo }}">
      <button wx:if="{{ canIUseGetUserProfile }}" bindtap="getUserProfile">获取头像昵称</button>
      <view wx:else class="userinfo-nickname">{{ motto }}</view>
    </block>
  </view>
</view>

<!-- 混合文本：hello … {{name}} … -->
<text>hello {{ name }} !</text>
<view data-mix="hello {{ name }} !"></view>

<!-- 多个插值同一行 -->
<text>{{ a }}{{ b }}</text>
<view data-ab="{{ a }}{{ b }}"></view>

<!-- 算术 / 逻辑 / 比较 -->
<text>{{ a + b * c - ((d / e) % 3) }}</text>
<text>{{ (a === b && c) || d }}</text>
<view data-arith="{{ a + b * c - ((d / e) % 3) }}"></view>
<view data-logic="{{ (a === b && c) || d }}"></view>

<!-- 一元与括号 -->
<text>{{ !flag }}</text>
<text>{{ (a + b) * c }}</text>
<view hidden="{{ !flag }}"></view>
<view data-paren="{{ (a + b) * c }}"></view>

<!-- 三元 -->
<text>{{ cond ? a : b }}</text>
<view class="{{ cond ? a : b }}"></view>

<!-- 成员访问与可选链 -->
<text>{{ user.info?.name }}</text>
<view data-chain="{{ user.info?.name }}"></view>

<!-- 数组字面量（属性与文本)，详见：https://developers.weixin.qq.com/miniprogram/dev/reference/wxml/data.html#数组 -->
<view wx:for="{{ [1, 2, 3] }}" wx:key="*this"></view>
<text>{{ [a, b] }}</text>
<view data-from-list="{{ [a, b] }}"></view>

<!-- WXML 对象写法：a:1,b:2 等价 {a:1,b:2}；先 `parseExpression` 失败则尝试 `{…}` 为对象字面量再 Prettier，去壳写回（非 {{ { } }}） -->
<text>{{ a: 1, b: 2 }}</text>
<view data-wxml-obj="{{ a: 1, b: 2 }}"></view>

<!-- WXML template / data 类对象简写（锁定当前格式化行为） -->
<template is="objectCombine" data="{{foo, bar}}"></template>
<template is="spreadMix" data="{{ ...a, ...b, c }}"></template>
<view data-comma-short="{{foo, bar}}"></view>

<!-- 函数调用与箭头函数 -->
<text>{{ fn(a, b) }}</text>
<text>{{ list.map((x) => x + 1) }}</text>
<view data-call="{{ fn(a, b) }}"></view>
<view data-arrow="{{ list.map((x) => x + 1) }}"></view>

<!-- 已规范输入应保持稳定 -->
<text>{{ user.name }}</text>
<view data-stable="{{ user.name }}"></view>

<!-- 字符串内含 `}}`（状态机须完整提取，非贪婪正则会截断） -->
<text>{{ "a}}" }}</text>
<view data-str-rbrace='{{ "a}}" }}'></view>

<!-- 字符串内含 `{{` -->
<text>{{ "{{x}}" }}</text>
<view data-str-brace="{{ "{{x}}" }}"></view>

<!-- 注释内 `{{}}` 不处理；下一行正文照常处理 -->
<!-- {{count+1}} -->
<text>after-comment {{ x }}</text>
<view data-after="{{ x }}"></view>

<!-- 非法表达式：保持原样 -->
<text>{{foo+}}</text>
<view data-bad="{{foo+}}"></view>

<!-- 语句类：非表达式，保持原样 -->
<text>{{ if (a) b }}</text>
<text>{{ return a }}</text>
<view data-stmt-if="{{ if (a) b }}"></view>
<view data-stmt-ret="{{ return a }}"></view>

<!-- 属性值中 `}}` 与闭合引号之间的空格须保留（语义相关），详见：https://developers.weixin.qq.com/miniprogram/dev/reference/wxml/data.html#对象 -->
<view wx:for="{{ [1, 2, 3] }} " wx:key="*this"></view>
