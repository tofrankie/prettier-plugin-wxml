{
  "wxmlStrict": false,
  "wxmlFormat": true,
  "wxmlSelfClose": true,
  "wxmlOrganizeAttributes": true,
  "attributeSort": "ASC",
  "attributeIgnoreCase": true,
  "attributeGroups": [
    "^for$",
    "^(if|elif|else)$",
    "^key$",
    "^for-item$",
    "^for-index$",
    "^slot$",
    "^id$",
    "^class$",
    "^hover-class$",
    "^hover-",
    "$DEFAULT",
    "^tap$",
    "^bind",
    "^catch",
    "^on",
    "^worklet"
  ]
}
